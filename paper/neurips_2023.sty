%% neurips_2023.sty -- self-contained NeurIPS-style layout (offline / portable).
%%
%% This is an INDEPENDENT reimplementation that reproduces the NeurIPS page
%% layout (5.5in x 9in centred text block on US-letter, 10pt Times, centred
%% title/author block, NeurIPS-style bold section headings, indented small
%% abstract, optional submission line numbers). It is NOT the copyrighted
%% official NeurIPS style file; it is kept dependency-light so the manuscript
%% builds OFFLINE with a base MiKTeX/TeXLive install and is portable to arXiv,
%% a workshop, and a future Datasets & Benchmarks resubmission. For a
%% camera-ready submission to a specific NeurIPS/D&B year, drop in that year's
%% official neurips_<year>.sty (the body markup here is compatible).
%%
%% Options:
%%   [preprint] -- authors shown, "Preprint." footer, no line numbers (arXiv).
%%   [final]    -- authors shown, no footer, no line numbers (camera-ready).
%%   [nonatbib] -- do not load natbib.
%%   (no option) -- anonymous-submission look with line numbers.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2023}[2026/06/25 v1.0 self-contained NeurIPS-style layout]

\newif\if@nips@final\@nips@finalfalse
\newif\if@nips@preprint\@nips@preprintfalse
\newif\if@nips@natbib\@nips@natbibtrue
\DeclareOption{final}{\@nips@finaltrue}
\DeclareOption{preprint}{\@nips@preprinttrue}
\DeclareOption{nonatbib}{\@nips@natbibfalse}
\ProcessOptions\relax

% ---- fonts: Times for text and math (psnfss; ships with base TeX) ----
\RequirePackage{mathptmx}

% ---- page geometry: NeurIPS 5.5in x 9in centred text block on US letter ----
\RequirePackage[letterpaper, textwidth=5.5in, textheight=9in,
                centering, headheight=12pt, footskip=30pt]{geometry}

% ---- bibliography ----
\if@nips@natbib
  \RequirePackage{natbib}
\fi

% ---- line numbers in submission mode only ----
\RequirePackage{lineno}
\if@nips@final\else
  \if@nips@preprint\else
    \linenumbers
  \fi
\fi

% ---- section heading style (bold, NeurIPS-ish sizes) ----
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.0ex \@plus -0.5ex \@minus -0.2ex}%
  {1.0ex \@plus 0.3ex}%
  {\normalfont\large\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-1.8ex \@plus -0.5ex \@minus -0.2ex}%
  {0.8ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}
\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-1.5ex \@plus -0.5ex \@minus -0.2ex}%
  {0.5ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}
\renewcommand\paragraph{\@startsection{paragraph}{4}{\z@}%
  {1.0ex \@plus 0.5ex \@minus 0.2ex}{-1em}%
  {\normalfont\normalsize\bfseries}}

% ---- footer line (page 1) as an unmarked footnote ----
\newcommand\blfootnote[1]{%
  \begingroup
    \renewcommand\thefootnote{}%
    \footnote{#1}%
    \addtocounter{footnote}{-1}%
  \endgroup
}
\def\@nips@footerline{}
\if@nips@preprint
  \def\@nips@footerline{Preprint. Under review.}
\else
  \if@nips@final
    \def\@nips@footerline{}
  \else
    \def\@nips@footerline{Submitted to the NeurIPS Datasets \& Benchmarks Track. Do not distribute.}
  \fi
\fi

% ---- title block ----
\renewcommand\maketitle{%
  \par
  \begingroup
    \centering
    {\LARGE\bfseries\@title\par}%
    \vskip 0.7em%
    {\large\@author\par}%
    \vskip 1.0em%
  \endgroup
  \ifx\@nips@footerline\empty\else
    \blfootnote{\@nips@footerline}%
  \fi
  \thispagestyle{plain}%
}

% ---- abstract: centred bold heading, small, indented both sides ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small
}{%
  \end{quote}
  \vspace{0.5ex}
}

% multi-author separators (parity with the official class; single-author safe)
\providecommand\And{\hspace{1.5em}}
\providecommand\AND{\\[0.3em]}

\endinput
